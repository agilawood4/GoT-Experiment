# 说明：
# - 下面不使用任何 $ 环境变量。
# - 跑在线/离线对比时，需要把 <...> 占位符替换成你的真实 run 目录。
# - 当前配置默认任务是 connectivity（--subset connectivity）。

# =========================
# 0) 环境准备（可执行一次）
# =========================
python -m pip install -U pip
python -m pip install -U datasets trl peft transformers accelerate pandas pyarrow huggingface_hub

# =========================
# 1) 冒烟测试（在线逐节点 DPO，小样本）
# =========================
python .\examples\graphwiz\graphwiz_eval_generic.py `
  --source test `
  --subset connectivity `
  --lm_name qwen_local_3b `
  --max_samples 12 `
  --budget 100 `
  --use_cache 0 `
  --online_dpo 1 `
  --online_pref_backend sqlite `
  --online_batch_size 4 `
  --online_update_interval_steps 4 `
  --online_min_node_gap 0.03 `
  --online_hot_swap 1 `
  --online_poll_interval_sec 2 `
  --online_dpo_beta 0.1 `
  --online_dpo_lr 5e-6 `
  --online_dpo_epochs 1 `
  --online_dpo_max_steps 10 `
  --online_max_checkpoints_keep 2

# 冒烟验证（把 <SMOKE_RUN_DIR> 换成刚刚生成的 run 目录）
python .\examples\graphwiz\verify_online_dpo_pipeline.py `
  --online_run_dir "examples/graphwiz/results/<SMOKE_RUN_DIR>" `
  --output "examples/graphwiz/results/<SMOKE_RUN_DIR>/online_verify_smoke.json"

# =========================
# 2) baseline 评测（无在线 DPO）
# =========================
python .\examples\graphwiz\graphwiz_eval_generic.py `
  --source test `
  --subset connectivity `
  --lm_name qwen_local_3b `
  --max_samples 120 `
  --budget 300 `
  --use_cache 0 `
  --online_dpo 0

# 记下本次 run 目录为：examples/graphwiz/results/<BASELINE_RUN_DIR>

# =========================
# 3) online DPO 完整评测（逐节点偏好 + 异步训练 + 热切换）
# =========================
python .\examples\graphwiz\graphwiz_eval_generic.py `
  --source test `
  --subset connectivity `
  --lm_name qwen_local_3b `
  --max_samples 120 `
  --budget 300 `
  --use_cache 0 `
  --online_dpo 1 `
  --online_pref_backend sqlite `
  --online_batch_size 16 `
  --online_update_interval_steps 16 `
  --online_min_node_gap 0.05 `
  --online_hot_swap 1 `
  --online_poll_interval_sec 5 `
  --online_dpo_beta 0.1 `
  --online_dpo_lr 5e-6 `
  --online_dpo_epochs 1 `
  --online_dpo_max_steps 30 `
  --online_max_checkpoints_keep 3

# 记下本次 run 目录为：examples/graphwiz/results/<ONLINE_RUN_DIR>

# 在线 DPO 对比 baseline 指标
python .\examples\graphwiz\verify_online_dpo_pipeline.py `
  --online_run_dir "examples/graphwiz/results/<ONLINE_RUN_DIR>" `
  --baseline_run_dir "examples/graphwiz/results/<BASELINE_RUN_DIR>" `
  --output "examples/graphwiz/results/<ONLINE_RUN_DIR>/online_verify_vs_baseline.json"

# =========================
# 4) 离线 DPO 训练（由 baseline + online 两次 run 导出偏好对）
# =========================
python .\examples\graphwiz\export_pref_data.py `
  --inputs "examples/graphwiz/results/<BASELINE_RUN_DIR>,examples/graphwiz/results/<ONLINE_RUN_DIR>" `
  --output "examples/graphwiz/data/graphwiz_pref_full.jsonl" `
  --min_reward_gap 0.05

python .\examples\graphwiz\train_dpo_trl.py `
  --model_name_or_path "./models/Qwen2.5-3B-Instruct" `
  --dataset_path "examples/graphwiz/data/graphwiz_pref_full.jsonl" `
  --output_dir "./outputs/trl_dpo_qwen25_3b_full" `
  --beta 0.1 `
  --learning_rate 5e-6 `
  --num_train_epochs 1 `
  --per_device_train_batch_size 1 `
  --gradient_accumulation_steps 8 `
  --logging_steps 10 `
  --save_steps 100 `
  --max_train_samples 0 `
  --bf16 1

# =========================
# 5) 把离线 DPO 模型注册成新的 lm_name（写入 config.json）
# =========================
python -c "import json; p=r'.\graph_of_thoughts\language_models\config.json'; cfg=json.load(open(p,'r',encoding='utf-8')); cfg['qwen_local_3b_dpo_full']={'backend':'local_hf','model_path':'./outputs/trl_dpo_qwen25_3b_full','tokenizer_path':'./outputs/trl_dpo_qwen25_3b_full','device_map':'auto','torch_dtype':'bfloat16','max_new_tokens':1024,'temperature':0.7,'top_p':0.9,'do_sample':True,'stop':None,'prompt_token_cost':0.0,'response_token_cost':0.0}; json.dump(cfg, open(p,'w',encoding='utf-8'), ensure_ascii=False, indent=2)"

# =========================
# 6) 评测离线 DPO 模型 + 手工对比指标（直接读取 summary.json）
# =========================
python .\examples\graphwiz\graphwiz_eval_generic.py `
  --source test `
  --subset connectivity `
  --lm_name qwen_local_3b_dpo_full `
  --max_samples 120 `
  --budget 300 `
  --use_cache 0 `
  --online_dpo 0

# 记下本次 run 目录为：examples/graphwiz/results/<DPO_EVAL_RUN_DIR>

python -c "import json, os; b='examples/graphwiz/results/<BASELINE_RUN_DIR>'; d='examples/graphwiz/results/<DPO_EVAL_RUN_DIR>'; sb=json.load(open(os.path.join(b,'summary.json'),'r',encoding='utf-8')); sd=json.load(open(os.path.join(d,'summary.json'),'r',encoding='utf-8')); out={'baseline_run':b,'dpo_eval_run':d,'baseline_accuracy':sb.get('accuracy',0.0),'dpo_accuracy':sd.get('accuracy',0.0),'accuracy_delta':sd.get('accuracy',0.0)-sb.get('accuracy',0.0),'baseline_mean_reward':sb.get('mean_reward',0.0),'dpo_mean_reward':sd.get('mean_reward',0.0),'mean_reward_delta':sd.get('mean_reward',0.0)-sb.get('mean_reward',0.0)}; op=os.path.join(d,'dpo_vs_baseline_metrics.json'); json.dump(out, open(op,'w',encoding='utf-8'), ensure_ascii=False, indent=2); print(json.dumps(out, ensure_ascii=False, indent=2)); print('Saved:', op)"

# =========================
# 7) 最终查看指标文件
# =========================
# 1) 在线 DPO 对比指标:
#    examples/graphwiz/results/<ONLINE_RUN_DIR>/online_verify_vs_baseline.json
#
# 2) 离线 DPO 对比指标:
#    examples/graphwiz/results/<DPO_EVAL_RUN_DIR>/dpo_vs_baseline_metrics.json
#
# 3) 每次 run 总览:
#    examples/graphwiz/results/<RUN_DIR>/summary.json
